{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "npm install",
      "group": "build"
    },

    {
      "label": "Run Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    {
      "label": "Build Website",
      "type": "shell",
      "command": "npm run build",
      "group": "build"
    },

    {
      "label": "Run Linter",
      "type": "shell",
      "command": "npm run lint"
    },

    {
      "label": "Type Check",
      "type": "shell",
      "command": "npx tsc --noEmit"
    },

    {
      "label": "Git Pull",
      "type": "shell",
      "command": "git pull origin main"
    },

    {
      "label": "Git Push",
      "type": "shell",
      "command": "git push origin main"
    },

    {
      "label": "Clean Next Cache",
      "type": "shell",
      "command": "rm -rf .next"
    }
  ]
}
